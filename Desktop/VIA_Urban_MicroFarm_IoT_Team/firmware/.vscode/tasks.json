{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build firmware (PlatformIO)",
			"type": "shell",
			"command": "platformio run",
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
		{
			"label": "Build main.c (PlatformIO)",
			"type": "shell",
			"command": "platformio run -t main.c",
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		}
	]
}